# Región de la PS Store (ej: en-US, es-CL). Default: en-US (más ofertas, tax-free).
PSN_REGION=en-US

# Category ID de la sección de ofertas en la PS Store US.
# Se obtiene de la URL: store.playstation.com/en-us/category/<UUID>/<N>
# Ejemplo de "Deals": 44d8bb20-653e-431e-8ad0-c0a365f68d2f (actualizar si cambia)
PSN_DEALS_CATEGORY_ID=44d8bb20-653e-431e-8ad0-c0a365f68d2f

# Hash SHA256 de la persisted query "categoryGridRetrieve".
# Si PSN responde PersistedQueryNotFound, abrir DevTools > Network en la página
# de la categoría, buscar la request a /api/graphql/v1/op?operationName=categoryGridRetrieve
# y copiar el valor de extensions.persistedQuery.sha256Hash.
PSN_CATEGORY_GRID_HASH=4ce7d4ce7a2a43fdf1dc4a8d93aa0cb087897d19ff0a7d7df6e3c829e79ec176

# Base de datos SQLite (ruta relativa al backend/).
DATABASE_URL=sqlite:///./apipsn.db
